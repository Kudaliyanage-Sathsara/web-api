# ============================================================================
# ALUMNI PROFILE API - Environment Configuration Example
# ============================================================================
# Copy this file to .env and update all values for your environment.
# NEVER commit the actual .env file to version control - it contains secrets!
#
# Supported environments: development, production, testing
# ============================================================================

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
# Set the environment: development, production, or testing
# Development: Shows detailed errors and debug info
# Production: Hides errors, optimizes performance
# Testing: Enables test mode with test database
ENVIRONMENT=development

# Base URL of your application (with trailing slash)
BASE_URL=http://localhost/alumni/

# Timezone for timestamp operations (PHP timezone identifier)
# Examples: UTC, America/New_York, Europe/London, Asia/Tokyo
TIMEZONE=UTC

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Primary database connection settings
DB_HOSTNAME=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=alumni_db
DB_DRIVER=mysqli

# Connection pooling and optimization
DB_PCONNECT=false
DB_DEBUG=true

# Character set and collation for database
DB_CHARSET=utf8
DB_COLLATION=utf8_general_ci

# Enable SSL for secure database connections (true/false)
DB_ENCRYPT=false

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Encryption key for sensitive data (generate with: openssl rand -base64 32)
# Must be at least 32 characters for secure encryption
ENCRYPTION_KEY=your-secure-encryption-key-here-min-32-chars

# Session configuration
SESSION_NAME=alumni_session
SESSION_TIMEOUT=1800
SESSION_REGENERATE=true

# CORS (Cross-Origin Resource Sharing) allowed origins
# Comma-separated list of domains allowed to access API
# Example: http://localhost:3000,http://localhost:8080,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Token security settings
TOKEN_EXPIRY_VERIFICATION=24
TOKEN_EXPIRY_PASSWORD_RESET=1
TOKEN_LENGTH=64

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Email service provider: sendmail, smtp, or mailgun
EMAIL_PROTOCOL=smtp

# SMTP Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password
SMTP_SECURE=tls

# From email address for system emails
EMAIL_FROM=noreply@alumni.university.edu
EMAIL_FROM_NAME=Alumni Profile System

# Mailgun configuration (if using Mailgun service)
MAILGUN_DOMAIN=mg.alumni.university.edu
MAILGUN_SECRET=key-xxxxxxxxxxxxxxxxxxxx

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
# Maximum file upload size in KB
MAX_UPLOAD_SIZE=2048

# Allowed file types for uploads (comma-separated)
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif

# Directory for profile image uploads (relative to FCPATH)
UPLOAD_DIRECTORY=uploads/profile_images/

# ============================================================================
# UNIVERSITY EMAIL VALIDATION
# ============================================================================
# Comma-separated list of allowed email domains for user registration
# Only users with these email domains can register
ALLOWED_EMAIL_DOMAINS=my.westminster.ac.uk,iit.ac.lk

# ============================================================================
# API CONFIGURATION
# ============================================================================
# API version for endpoint versioning
API_VERSION=v1

# Rate limiting: requests per minute per IP
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Enable API request logging (true/false)
API_LOG_REQUESTS=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: error, warning, info, debug
# error: Only errors are logged
# warning: Errors and warnings
# info: General information, warnings, and errors
# debug: All information including debug messages
LOG_LEVEL=debug

# Log file location (relative to application root)
LOG_PATH=application/logs/

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
# Cache backend: memcached, redis, file, or none
CACHE_BACKEND=file

# Memcached configuration
CACHE_MEMCACHED_HOST=localhost
CACHE_MEMCACHED_PORT=11211

# Redis configuration
CACHE_REDIS_HOST=localhost
CACHE_REDIS_PORT=6379
CACHE_REDIS_PASSWORD=

# Cache TTL (Time To Live) in seconds
CACHE_TTL=3600

# ============================================================================
# PASSWORD POLICY
# ============================================================================
# Minimum password length (recommended: 8+)
PASSWORD_MIN_LENGTH=8

# Require uppercase letters in password (true/false)
PASSWORD_REQUIRE_UPPERCASE=true

# Require numbers in password (true/false)
PASSWORD_REQUIRE_NUMBERS=true

# Require special characters (true/false)
PASSWORD_REQUIRE_SPECIAL=false

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# LinkedIn API configuration (for profile enrichment)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Google Maps API key (for location services, if needed)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================
# Enable error tracking service (Sentry, Rollbar, etc.)
ERROR_TRACKING_ENABLED=false
ERROR_TRACKING_DSN=

# Enable analytics tracking
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=google

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================
# Enable CodeIgniter Profiler for performance analysis
CI_PROFILER_ENABLED=false

# Enable query log database profiling
QUERY_LOG_ENABLED=true

# Display errors in browser (development only, never in production!)
DISPLAY_ERRORS=true

# ============================================================================
# NOTES
# ============================================================================
# 1. Always keep sensitive data (passwords, API keys) in .env, never in code
# 2. Generate strong encryption keys: openssl rand -base64 32
# 3. Use environment-specific .env files for different deployments
# 4. Never commit .env files to version control
# 5. Restrict .env file permissions: chmod 600 .env
# 6. Document any custom environment variables added to your project
